# Configurações SMTP para envio de e-mail do formulário de contato
# Copie este arquivo para .env e preencha com as credenciais reais

# Servidor SMTP (ex: smtp.gmail.com, smtp.hostinger.com, mail.sixtech.com.br)
SMTP_HOST=smtp.gmail.com

# Porta SMTP (587 = TLS/STARTTLS, 465 = SSL, 25 = sem criptografia)
SMTP_PORT=587

# Use true somente para porta 465 (SSL direto), false para 587 (STARTTLS)
SMTP_SECURE=false

# Usuário/login do SMTP (normalmente o próprio e-mail)
SMTP_USER=seu-email@gmail.com

# Senha do SMTP
# Gmail: gere uma "Senha de app" em myaccount.google.com/apppasswords
SMTP_PASS=sua-senha-de-app

# Remetente exibido no e-mail
SMTP_FROM="Sixtech <seu-email@gmail.com>"

# Destinatário que receberá as mensagens do formulário
CONTACT_EMAIL=comercial@sixtech.com.br
