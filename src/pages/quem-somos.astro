---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuemSomosHero from '../components/quem-somos/QuemSomosHero.astro';
import QuemSomosMissionVision from '../components/quem-somos/QuemSomosMissionVision.astro';
import WhyChooseSixTech from '../components/WhyChooseSixTech.astro';
import CallToAction from '../components/CallToAction.astro';
import '../styles/quem-somos.css';
---

<Layout
	title="sixtech — Quem somos"
	description="Somos a Six Tech — desenvolvimento de sistemas com quase 30 anos de experiência. Soluções tecnológicas sob medida em Curitiba desde 1996."
>
	<div class="page-hero page-quem-somos">
		<Header active="quem-somos" />
		<QuemSomosHero />
	</div>
	<main class="page-quem-somos-main">
		<div class="qs-stack">
			<QuemSomosMissionVision />
			<WhyChooseSixTech sectionId="por-que-sixtech" />
			<CallToAction 
				title="Venha nos conhecer!"
				text="Agende uma conversa on-line e descubra como nossa trajetória de inovação pode impulsionar suas soluções!"
				buttonText="Conheça a SixTech"
				buttonHref="/#contato"
			/>
		</div>
	</main>
	<Footer />
</Layout>
