---
import HeadingAccentBar from "./HeadingAccentBar.astro";

interface Props {
	title: string;
	text: string;
	buttonText: string;
	buttonHref?: string;
}

const {
	title,
	text,
	buttonText,
	buttonHref = "#contato"
} = Astro.props;
---

<section class="cta-section" aria-labelledby="cta-heading">
	<div class="cta-section__inner">
		<div class="cta-section__header">
			<h2 id="cta-heading" class="cta-section__title heading-with-accent heading-with-accent--center">
				{title}<HeadingAccentBar />
			</h2>
			<p class="cta-section__text">
				{text}
			</p>
		</div>

		<a href={buttonHref} class="btn-blue">
			{buttonText}
		</a>
	</div>
</section>

<style>
	.cta-section {
		width: 100%;
		padding: 10rem 0;
		text-align: center;
	}

	.cta-section__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		width: 100%;
		max-width: 42rem;
		margin-inline: auto;
		gap: 3rem;
	}

	.cta-section__header {
		display: flex;
		width: 100%;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}

	.cta-section__title {
		margin: 0;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		line-height: 1.2;
		color: var(--text-main);
		letter-spacing: -0.02em;
	}

	.cta-section__text {
		margin: 0;
		font-size: clamp(1rem, 2vw, 1.125rem);
		font-weight: 400;
		line-height: 1.5;
		color: var(--text-main);
	}

	@media (max-width: 767px) {
		.cta-section {
			padding: var(--section-padding-y-mobile) 0;
		}

		.cta-section__inner {
			gap: 2rem;
		}

		.cta-section__header {
			gap: 1rem;
		}

		.cta-section__title {
			font-size: 2rem;
		}

		.cta-section__text {
			font-size: 1rem;
		}
	}
</style>
