---
---

<section class="contato-hero" aria-labelledby="contato-hero-heading">
	<div class="contato-hero__bg" aria-hidden="true">
		<img
			class="contato-hero__bg-img"
			src="/images/contato/hero-background.jpg"
			width="1280"
			height="800"
			alt=""
			loading="eager"
			decoding="async"
		/>
	</div>
	<div class="contato-hero__readability" aria-hidden="true"></div>
	<div class="contato-hero__shell container">
		<div class="contato-hero__inner">
			<h1 id="contato-hero-heading" class="contato-hero__title">
				Entre em contato
			</h1>
			<p class="contato-hero__lead font-inter">
				Estamos prontos para ouvir suas ideias, tirar dúvidas e ajudar sua empresa a inovar com tecnologia.
			</p>
		</div>
	</div>
</section>

<style>
	.contato-hero {
		position: relative;
		display: flex;
		overflow: hidden;
		min-height: 100vh;
		align-items: center;
		background: var(--color-figma-primary);
		padding-top: calc(var(--header-h) + 2rem);
		padding-bottom: 3rem;
	}

	.contato-hero__bg {
		pointer-events: none;
		position: absolute;
		z-index: 0;
		inset: 0;
	}

	.contato-hero__bg-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		/* Retrato à direita — Figma Contato (152:803) */
		object-position: 82% 42%;
	}

	.contato-hero__readability {
		pointer-events: none;
		position: absolute;
		z-index: 0;
		inset: 0;
		background: linear-gradient(
			100deg,
			rgba(30, 58, 138, 0.88) 0%,
			rgba(30, 58, 138, 0.45) 52%,
			rgba(30, 58, 138, 0.12) 100%
		);
	}

	.contato-hero__shell {
		position: relative;
		z-index: 1;
	}

	.contato-hero__inner {
		display: flex;
		width: 100%;
		max-width: 45.125rem; /* 722px — bloco texto Figma (152:811) */
		flex-direction: column;
		align-items: flex-start;
		gap: 2rem; /* 32px */
	}

	.contato-hero__title {
		margin: 0;
		font-family: inherit;
		font-size: clamp(1.75rem, 4vw, 3rem); /* 48px desktop */
		font-weight: 700;
		line-height: 1.1;
		text-align: left;
		text-transform: uppercase;
		color: var(--text-main);
	}

	.contato-hero__lead {
		margin: 0;
		max-width: 45.125rem;
		font-size: clamp(1.125rem, 3vw, 1.5rem); /* ~24px desktop — Figma */
		font-weight: 400;
		line-height: normal;
		color: var(--text-main);
	}

	/* Figma Contato mobile (184:1528): título 32px, lead 16px */
	@media (max-width: 767px) {
		.contato-hero__title {
			font-size: 2rem; /* 32px */
		}

		.contato-hero__lead {
			font-size: var(--fs-base); /* 16px */
		}
	}
</style>
