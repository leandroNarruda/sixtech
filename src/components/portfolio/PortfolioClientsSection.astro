---
/**
 * Seção “Nossos clientes” → CTA “Junte-se a eles” (Figma node 152:792–152:799).
 * Logos: `public/companies` via `clientStrip.ts`.
 */
import HeadingAccentBar from "../HeadingAccentBar.astro";
import ClientStripLogo from "../ClientStripLogo.astro";
import { clients } from "../../data/clientStrip";
---

<section class="portfolio-clients" aria-labelledby="portfolio-clients-heading">
	<div class="portfolio-clients__inner container">
		<header class="portfolio-clients__intro">
			<h2 id="portfolio-clients-heading" class="portfolio-clients__title heading-with-accent">
				Nossos Clientes<HeadingAccentBar />
			</h2>
			<p class="portfolio-clients__lead">
				Orgulhosos de parcerias com empresas que transformamos.
			</p>
		</header>

		<div class="portfolio-clients__logos" role="list">
			{clients.map((client) => (
				<div class="portfolio-clients__logo-item" role="listitem">
					<ClientStripLogo client={client} />
				</div>
			))}
		</div>

		<div class="portfolio-clients__cta-block">
			<p class="portfolio-clients__cta-text">
				Conheça quem já utilizou nossas soluções para crescer.
			</p>
			<a href="/#contato" class="btn btn-blue">Junte-se a eles</a>
		</div>
	</div>
</section>

<style>
	.portfolio-clients {
		background: var(--bg-dark);
		padding-block: clamp(3.5rem, 10vw, 6.25rem);
	}

	.portfolio-clients__inner {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 5rem;
	}

	.portfolio-clients__intro {
		display: flex;
		max-width: 36rem;
		flex-direction: column;
		gap: 2.5rem;
	}

	.portfolio-clients__title {
		margin: 0;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		line-height: 1.2;
		color: var(--text-main);
		letter-spacing: -0.02em;
	}

	.portfolio-clients__lead {
		margin: 0;
		max-width: 34.5rem;
		font-family: var(--font-roboto);
		font-size: 1.25rem;
		font-weight: 400;
		line-height: 1.5;
		color: var(--text-main);
	}

	.portfolio-clients__logos {
		display: flex;
		width: 100%;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 3vw, 1.5rem);
	}

	.portfolio-clients__logo-item {
		display: flex;
		flex: 0 1 auto;
		align-items: center;
		justify-content: center;
	}

	/* Figma: logos claros sobre fundo escuro */
	.portfolio-clients__logos :global(.client-strip__logo-img) {
		filter: brightness(0) invert(1);
		opacity: 0.95;
	}

	.portfolio-clients__cta-block {
		display: flex;
		max-width: 32rem;
		flex-direction: column;
		align-items: flex-start;
		gap: 2.5rem;
	}

	.portfolio-clients__cta-text {
		margin: 0;
		font-family: var(--font-roboto);
		font-size: 1.25rem;
		font-weight: 400;
		line-height: 1.5;
		color: var(--text-main);
	}

	@media (max-width: 767px) {
		.portfolio-clients__inner {
			gap: 2rem;
		}

		.portfolio-clients__intro {
			gap: 1.5rem;
		}

		.portfolio-clients__logos {
			justify-content: center;
		}

		.portfolio-clients__cta-block {
			gap: 1.5rem;
		}
	}
</style>
