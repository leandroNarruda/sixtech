---
import type { PortfolioCardData } from '../../data/portfolio';

type Props = PortfolioCardData;

const { title, description, imageSrc, imageAlt, gradient, variant = 'default' } = Astro.props;
const { from: gradientFrom, to: gradientTo } = gradient;
---

<article
	class:list={['portfolio-card', { 'portfolio-card--green': variant === 'green' }]}
	style={`--card-gradient-from: ${gradientFrom}; --card-gradient-to: ${gradientTo};`}
>
	<div class="portfolio-card__visual" aria-hidden="true">
		<div class="portfolio-card__visual-back"></div>
		<div class="portfolio-card__visual-frame"></div>
		<div class="portfolio-card__visual-inner">
				<img
					class="portfolio-card__img"
					src={imageSrc}
					alt={imageAlt}
					loading="lazy"
					decoding="async"
					width="330"
					height="428"
					draggable="false"
				/>
		</div>
	</div>
	<div class="portfolio-card__body">
		<h3 class="portfolio-card__title">{title}</h3>
		<p class="portfolio-card__desc">{description}</p>
	</div>
</article>

<style>
	.portfolio-card {
		--card-bg: #222d2f;
		--card-text: var(--color-figma-gray, #d1d5db);
		display: flex;
		height: 100%;
		width: 100%;
		max-width: 22.375rem; /* 358px */
		flex-shrink: 0;
		flex-direction: column;
		align-items: stretch;
		gap: 1.375rem; /* 22px */
		border-radius: 1.5rem; /* 24px */
		background: var(--card-bg);
		padding: 1.5rem;
	}

	.portfolio-card__visual {
		position: relative;
		overflow: hidden;
		width: 100%;
		aspect-ratio: 358 / 467;
		border-radius: 0.75rem;
	}

	.portfolio-card__visual-back {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			180deg,
			var(--card-gradient-from) 0%,
			var(--card-gradient-to) 100%
		);
	}

	.portfolio-card__visual-frame {
		position: absolute;
		inset: 6.2% 0 0 7.8%;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-right: none;
		border-bottom: none;
		border-radius: 1.625rem 0 0 0;
		background: rgba(0, 0, 0, 0.12);
		pointer-events: none;
	}

	.portfolio-card__visual-inner {
		position: absolute;
		inset: 10.5% 0 0 13.4%;
		overflow: hidden;
		border-radius: 0.8125rem 0 0 0;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-right: none;
		border-bottom: none;
	}

	.portfolio-card__img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
	}

	.portfolio-card__body {
		display: flex;
		flex-direction: column;
		gap: 1.375rem;
		line-height: normal;
		color: var(--card-text);
	}

	.portfolio-card__title {
		margin: 0;
		font-family: inherit;
		font-size: 1.5rem; /* 24px — Figma */
		font-weight: 700;
		line-height: 1.25;
		color: var(--text-main);
	}

	.portfolio-card__desc {
		margin: 0;
		font-family: inherit;
		font-size: var(--fs-base);
		font-weight: 400;
		line-height: 1.5;
		color: var(--card-text);
	}

	/**
	 * Mobile — Figma node 184:1472: p 16px, gap 22px (imagem↔texto), gap 16px (título↔desc),
	 * título 16px bold, corpo 12px, área visual aspect 310/467.
	 */
	@media (max-width: 767px) {
		.portfolio-card {
			max-width: min(22.375rem, 100%);
			padding: 1rem;
			gap: 1.375rem; /* 22px */
		}

		.portfolio-card__visual {
			aspect-ratio: 310 / 467;
		}

		/* Frame mobile — Figma ~358×467 (11px, 15.8px, 231×307) */
		.portfolio-card__visual-frame {
			inset: 3.38% 0 0 3.07%;
			border-radius: 1.625rem 0 0 0;
		}

		.portfolio-card__visual-inner {
			inset: 10.5% 0 0 13.41%;
			border-radius: 0.8125rem 0 0 0;
		}

		.portfolio-card__body {
			gap: 1rem; /* 16px */
		}

		.portfolio-card__title {
			font-size: 1rem; /* 16px */
			line-height: normal;
		}

		.portfolio-card__desc {
			font-size: 0.75rem; /* 12px */
			line-height: 1.5;
		}
	}

	/* Variantes - Green */
	.portfolio-card--green .portfolio-card__visual-frame {
		background: #1dbc61;
		border-color: #8df8bb;
	}
</style>
