---
import { useTranslations } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

const lang = (Astro.currentLocale ?? 'pt') as Lang;
const t = useTranslations(lang);
---

<section class="portfolio-hero" aria-labelledby="portfolio-hero-heading">
	<div class="portfolio-hero__bg" aria-hidden="true">
		<img
			class="portfolio-hero__bg-img"
			src="/images/portfolio/hero-background.jpg"
			width="1280"
			height="800"
			alt=""
			loading="eager"
			decoding="async"
		/>
	</div>
	<div class="portfolio-hero__readability" aria-hidden="true"></div>
	<div class="portfolio-hero__shell container">
		<div class="portfolio-hero__inner">
			<h1 id="portfolio-hero-heading" class="portfolio-hero__title">
				{t('portfolio.hero.title')}
			</h1>
			<p class="portfolio-hero__lead font-inter">
				{t('portfolio.hero.lead')}
			</p>
		</div>
	</div>
</section>

<style>
	.portfolio-hero {
		position: relative;
		display: flex;
		overflow: hidden;
		min-height: 100vh;
		align-items: center;
		background: var(--color-figma-primary);
		padding-top: calc(var(--header-h) + 2rem);
		padding-bottom: 3rem;
	}

	.portfolio-hero__bg {
		pointer-events: none;
		position: absolute;
		z-index: 0;
		inset: 0;
	}

	.portfolio-hero__bg-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 72% 42%;
	}

	.portfolio-hero__readability {
		pointer-events: none;
		position: absolute;
		z-index: 0;
		inset: 0;
		background: linear-gradient(
			100deg,
			rgba(30, 58, 138, 0.88) 0%,
			rgba(30, 58, 138, 0.45) 52%,
			rgba(30, 58, 138, 0.12) 100%
		);
	}

	.portfolio-hero__shell {
		position: relative;
		z-index: 1;
	}

	.portfolio-hero__inner {
		display: flex;
		width: 100%;
		max-width: 45.125rem;
		flex-direction: column;
		align-items: flex-start;
		gap: 2rem;
	}

	.portfolio-hero__title {
		margin: 0;
		font-family: inherit;
		font-size: clamp(1.75rem, 4vw, 3rem);
		font-weight: 700;
		line-height: 1.1;
		text-align: left;
		text-transform: uppercase;
		color: var(--text-main);
	}

	.portfolio-hero__lead {
		margin: 0;
		max-width: 45.125rem;
		font-size: clamp(1.125rem, 3vw, 2rem);
		font-weight: 400;
		line-height: normal;
		color: var(--text-main);
	}
</style>
