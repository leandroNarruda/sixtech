---
---

<section class="hero" aria-labelledby="hero-heading">
	<div class="hero__overlay" aria-hidden="true"></div>
	<div class="hero__content container">
		<div>
			<h1 id="hero-heading" class="hero__title">
				<span class="hero__line hero__line--light">Transformamos</span>
				<span class="hero__line hero__line--accent">Ideias em sistemas</span>
				<span class="hero__line hero__line--body">que impulsionam negócios</span>
			</h1>
			<a class="hero__cta" href="#contato">Solicite uma proposta gratuita</a>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		display: flex;
		min-height: 100vh;
		align-items: center;
		background-image: url("/images/hero.png");
		background-size: cover;
		background-position: right center;
		background-repeat: no-repeat;
		padding-top: calc(var(--header-h) + 2rem);
		padding-inline: 1.5rem;
		padding-bottom: 3rem;
	}

	.hero__overlay {
		pointer-events: none;
		position: absolute;
		inset: 0;
	}

	.hero__content {
		position: relative;
		z-index: 10;
	}

	.hero__title {
		margin: 0 0 2rem;
		line-height: 1.15;
		text-align: left;
	}

	.hero__line {
		display: block;
		color: var(--text-main);
	}

	.hero__line--light {
		font-weight: 300;
		font-size: var(--fs-xl);
	}

	.hero__line--accent {
		margin-block: 0.35rem;
		font-size: var(--fs-2xl);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.hero__line--body {
		font-weight: 400;
		font-size: var(--fs-xl);
	}

	.hero__cta {
		font-size: 1.25rem;
		font-weight: 400;
		padding: 0.5rem 1rem;
		border-radius: 31px;
		border: 1px solid #fff;
		color: #fff;
	}
</style>
