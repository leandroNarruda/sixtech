---
---

<section class="hero" aria-labelledby="hero-heading">
	<div class="hero__overlay" aria-hidden="true"></div>
	<div class="hero__content container">
		<div class="hero__stack">
			<h1 id="hero-heading" class="hero__title">
				<span class="hero__line hero__line--light">Transformamos</span>
				<span class="hero__line hero__line--accent">Ideias em sistemas</span>
				<span class="hero__line hero__line--body">que impulsionam negócios</span>
			</h1>
			<a class="hero__cta" href="#contato">Solicite uma proposta gratuita</a>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		display: flex;
		min-height: 100vh;
		align-items: center;
		background-image: url("/images/hero.png");
		background-size: cover;
		background-position: right center;
		background-repeat: no-repeat;
		padding-top: calc(var(--header-h) + 2rem);
		padding-bottom: 3rem;
	}

	.hero__overlay {
		pointer-events: none;
		position: absolute;
		inset: 0;
		z-index: 1;
	}

	.hero__content {
		position: relative;
		z-index: 10;
	}

	.hero__stack {
		display: flex;
		max-width: 100%;
		flex-direction: column;
		align-items: flex-start;
		gap: 1rem;
	}

	.hero__title {
		margin: 0;
		line-height: 1.15;
		text-align: left;
	}

	.hero__line {
		display: block;
		color: var(--text-main);
	}

	.hero__line--light {
		font-weight: 300;
		font-size: var(--fs-xl);
	}

	.hero__line--accent {
		margin-block: 0.35rem;
		font-size: var(--fs-2xl);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.hero__line--body {
		font-weight: 400;
		font-size: var(--fs-xl);
	}

	.hero__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-size: 1.25rem;
		font-weight: 400;
		padding: 0.5rem 1rem;
		border-radius: 5rem;
		border: 1px solid #fff;
		color: #fff;
		text-decoration: none;
		transition:
			background 0.2s,
			color 0.2s;
	}

	.hero__cta:hover,
	.hero__cta:focus-visible {
		background: rgba(255, 255, 255, 0.12);
	}

	.hero__cta:focus-visible {
		outline: 2px solid var(--accent-cyan);
		outline-offset: 3px;
	}

	@media (max-width: 767px) {
		.hero__overlay {
			background: linear-gradient(
				90deg,
				color-mix(in srgb, var(--color-figma-primary) 92%, #000) 0%,
				color-mix(in srgb, var(--color-figma-primary) 55%, transparent) 42%,
				color-mix(in srgb, var(--color-figma-accent) 18%, transparent) 62%,
				transparent 78%
			);
		}

		.hero {
			/* Conteúdo centralizado na área da imagem; padding-top só libera o header absoluto */
			flex-direction: column;
			justify-content: center;
			align-items: stretch;
			min-height: min(100vh, 50rem);
			background-position: 85% center;
			background-size: cover;
			padding-top: var(--header-h-mobile);
			padding-bottom: 2.5rem;
		}

		.hero__title {
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			gap: 0;
		}

		.hero__line--light {
			font-size: var(--hero-mobile-line-light);
			font-weight: 300;
			line-height: normal;
		}

		.hero__line--accent {
			margin-block: 0;
			font-size: var(--hero-mobile-line-accent);
			font-weight: 700;
			line-height: 2.25rem;
			white-space: nowrap;
		}

		.hero__line--body {
			font-size: var(--hero-mobile-line-body);
			font-weight: 400;
			line-height: normal;
			white-space: nowrap;
		}

		.hero__cta {
			font-size: var(--hero-mobile-cta-size);
			line-height: normal;
			padding: 0.5rem 1rem;
			border-radius: 5rem;
		}
	}

	@media (max-width: 359px) {
		.hero__line--accent,
		.hero__line--body {
			white-space: normal;
		}
	}
</style>
