---
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'pt') as Lang;
const t = useTranslations(lang);
const formAction = lang === 'en' ? '/en/contact' : '/contato';
---

<div
	class="contato-modal__backdrop"
	id="contato-modal-backdrop"
	hidden
	aria-hidden="true"
></div>

<div
	class="contato-modal"
	id="contato-modal"
	role="dialog"
	aria-modal="true"
	aria-labelledby="contato-modal-title"
	hidden
>
	<div class="contato-modal__panel">
		<button
			type="button"
			class="contato-modal__close"
			data-modal-close
			aria-label={t('modal.closeAria')}
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
		</button>

		<h2 id="contato-modal-title" class="contato-modal__title">{t('modal.title')}</h2>

		<form
			class="contato-modal__form"
			name="contato"
			method="POST"
			data-netlify="true"
			netlify-honeypot="bot-field"
			action={formAction}
		>
			<input type="hidden" name="form-name" value="contato" />

			<p class="visually-hidden">
				<label>
					{t('contato.form.honeypot')}
					<input name="bot-field" tabindex="-1" autocomplete="off" />
				</label>
			</p>

			<div class="contato-modal__field">
				<label class="visually-hidden" for="modal-contato-nome">{t('contato.form.name.label')}</label>
				<input
					id="modal-contato-nome"
					class="contato-modal__input"
					type="text"
					name="nome"
					autocomplete="name"
					placeholder={t('contato.form.name.placeholder')}
					required
				/>
			</div>

			<div class="contato-modal__field">
				<label class="visually-hidden" for="modal-contato-email">{t('contato.form.email.label')}</label>
				<input
					id="modal-contato-email"
					class="contato-modal__input"
					type="email"
					name="email"
					autocomplete="email"
					inputmode="email"
					placeholder={t('contato.form.email.placeholder')}
					required
				/>
			</div>

			<div class="contato-modal__field">
				<label class="visually-hidden" for="modal-contato-telefone">{t('contato.form.phone.label')}</label>
				<input
					id="modal-contato-telefone"
					class="contato-modal__input"
					type="tel"
					name="telefone"
					autocomplete="tel"
					inputmode="tel"
					placeholder={t('contato.form.phone.placeholder')}
					required
				/>
			</div>

			<div class="contato-modal__field">
				<label class="visually-hidden" for="modal-contato-mensagem">{t('contato.form.message.label')}</label>
				<textarea
					id="modal-contato-mensagem"
					class="contato-modal__textarea"
					name="mensagem"
					rows="4"
					placeholder={t('contato.form.message.placeholder')}
					required
				></textarea>
			</div>

			<div class="contato-modal__field contato-modal__field--checkbox">
				<input
					id="modal-contato-privacidade"
					class="contato-modal__checkbox"
					type="checkbox"
					name="privacidade"
					value="aceito"
					required
				/>
				<label class="contato-modal__checkbox-label" for="modal-contato-privacidade">
					{t('contato.form.privacy')}
				</label>
			</div>

			<div class="contato-modal__actions">
				<button type="submit" class="btn btn-blue contato-modal__submit">{t('contato.form.submit')}</button>
			</div>
		</form>
	</div>
</div>

<script>
	const modalEl = document.getElementById('contato-modal') as HTMLElement | null;
	const backdropEl = document.getElementById('contato-modal-backdrop') as HTMLElement | null;

	if (modalEl && backdropEl) {
		let lastFocused: HTMLElement | null = null;

		function openModal(trigger?: Element | null) {
			if (trigger instanceof HTMLElement) lastFocused = trigger;
			else lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
			modalEl!.hidden = false;
			backdropEl!.hidden = false;
			document.body.classList.add('modal-open');
			const first = modalEl!.querySelector<HTMLElement>('input:not([type=hidden]):not([tabindex="-1"]), textarea, button');
			if (first) first.focus();
		}

		function closeModal() {
			modalEl!.hidden = true;
			backdropEl!.hidden = true;
			document.body.classList.remove('modal-open');
			if (lastFocused) lastFocused.focus();
		}

		// Auto-attach to any [data-modal-contato] elements
		document.querySelectorAll('[data-modal-contato]').forEach((el) => {
			el.addEventListener('click', () => openModal(el));
		});

		// Backdrop click closes
		backdropEl.addEventListener('click', closeModal);

		// Close button inside modal
		modalEl.querySelector('[data-modal-close]')?.addEventListener('click', closeModal);

		// Escape key closes
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !modalEl!.hidden) closeModal();
		});

		// Expose globally
		(window as any).openContatoModal = openModal;
		(window as any).closeContatoModal = closeModal;
	}
</script>

<style>
	.contato-modal__backdrop {
		position: fixed;
		inset: 0;
		z-index: 300;
		background: rgba(0, 0, 0, 0.65);
		cursor: pointer;
	}

	.contato-modal__backdrop[hidden] {
		display: none !important;
	}

	.contato-modal {
		position: fixed;
		inset: 0;
		z-index: 310;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.5rem var(--page-gutter, 1.5rem);
		pointer-events: none;
		overflow-y: auto;
	}

	.contato-modal[hidden] {
		display: none !important;
	}

	.contato-modal__panel {
		--modal-field-bg: #222d2f;
		--modal-field-border: #2a393b;
		--modal-field-text: var(--color-figma-gray);

		position: relative;
		pointer-events: all;
		width: 100%;
		max-width: 40rem;
		background: var(--color-figma-surface);
		border-radius: 2.5rem;
		padding: clamp(2rem, 5vw, 3rem) clamp(1.5rem, 5vw, 3rem);
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.contato-modal__close {
		position: absolute;
		top: 1.25rem;
		right: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border: none;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.08);
		color: var(--text-main);
		cursor: pointer;
		transition: background 0.2s;
	}

	.contato-modal__close:hover,
	.contato-modal__close:focus-visible {
		background: rgba(255, 255, 255, 0.16);
	}

	.contato-modal__close:focus-visible {
		outline: 2px solid var(--accent-cyan);
		outline-offset: 2px;
	}

	.contato-modal__title {
		margin: 0;
		font-size: clamp(1.25rem, 3vw, 1.75rem);
		font-weight: 700;
		color: var(--text-main);
		line-height: 1.2;
		padding-right: 2.5rem; /* space for close button */
	}

	.contato-modal__form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.contato-modal__field {
		margin: 0;
	}

	.contato-modal__input {
		box-sizing: border-box;
		width: 100%;
		height: 3.5rem;
		border-radius: 5rem;
		border: 1px solid var(--modal-field-border);
		background: var(--modal-field-bg);
		padding: 1.125rem 2rem;
		font: inherit;
		font-size: var(--fs-base);
		font-weight: 400;
		line-height: normal;
		color: var(--text-main);
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.contato-modal__input::placeholder {
		color: var(--modal-field-text);
	}

	.contato-modal__input:hover {
		border-color: rgba(209, 213, 219, 0.35);
	}

	.contato-modal__input:focus-visible {
		border-color: var(--accent-cyan);
		outline: none;
		box-shadow: 0 0 0 2px rgba(51, 232, 255, 0.25);
	}

	.contato-modal__textarea {
		box-sizing: border-box;
		width: 100%;
		min-height: 8rem;
		resize: vertical;
		border-radius: 1.5rem;
		border: 1px solid var(--modal-field-border);
		background: var(--modal-field-bg);
		padding: 1.25rem 2rem;
		font: inherit;
		font-size: var(--fs-base);
		font-weight: 400;
		line-height: 1.45;
		color: var(--text-main);
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.contato-modal__textarea::placeholder {
		color: var(--modal-field-text);
	}

	.contato-modal__textarea:hover {
		border-color: rgba(209, 213, 219, 0.35);
	}

	.contato-modal__textarea:focus-visible {
		border-color: var(--accent-cyan);
		outline: none;
		box-shadow: 0 0 0 2px rgba(51, 232, 255, 0.25);
	}

	.contato-modal__field--checkbox {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.contato-modal__checkbox {
		appearance: none;
		-webkit-appearance: none;
		position: relative;
		flex-shrink: 0;
		box-sizing: border-box;
		width: 1.5rem;
		height: 1.5rem;
		margin: 0;
		border-radius: 0.25rem;
		border: 1px solid var(--modal-field-border);
		background-color: var(--modal-field-bg);
		cursor: pointer;
	}

	.contato-modal__checkbox:checked {
		border-color: var(--color-figma-primary);
		background-color: var(--color-figma-primary);
	}

	.contato-modal__checkbox:checked::after {
		content: "";
		position: absolute;
		left: 50%;
		top: 50%;
		width: 0.375rem;
		height: 0.6875rem;
		border: 2.5px solid var(--text-main);
		border-top: 0;
		border-left: 0;
		transform: translate(-50%, -58%) rotate(45deg);
	}

	.contato-modal__checkbox:focus-visible {
		outline: 2px solid var(--accent-cyan);
		outline-offset: 2px;
	}

	.contato-modal__checkbox-label {
		font-size: var(--fs-base);
		font-weight: 400;
		line-height: normal;
		color: var(--modal-field-text);
		cursor: pointer;
	}

	.contato-modal__actions {
		display: flex;
		align-items: center;
	}

	.contato-modal__submit {
		border: none;
		cursor: pointer;
		font-family: inherit;
	}

	@media (max-width: 767px) {
		.contato-modal {
			align-items: flex-end;
			padding: 0;
		}

		.contato-modal__panel {
			border-bottom-left-radius: 0;
			border-bottom-right-radius: 0;
			max-width: 100%;
			padding: 2rem 1.5rem 2.5rem;
		}

		.contato-modal__input,
		.contato-modal__textarea {
			font-size: 0.75rem;
		}

		.contato-modal__checkbox-label {
			font-size: 0.75rem;
		}
	}
</style>
