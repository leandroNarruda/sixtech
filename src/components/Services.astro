---
import HeadingAccentBar from "./HeadingAccentBar.astro";
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'pt') as Lang;
const t = useTranslations(lang);
---

<section id="servicos" class="services">
	<div class="container">
		<div class="services__inner">
		<!-- Left column: text content -->
		<div class="services__col-left">
			<div class="services__title-row">
				<h2 class="services__heading heading-with-accent" id="services-heading">
					{t('services.heading')}<HeadingAccentBar />
				</h2>
			</div>

			<div class="services__intro">
				<p class="services__lead">
					{t('services.lead1')}
				</p>
				<p class="services__lead">
					{t('services.lead2')}
				</p>
			</div>

			<ul class="services__list" aria-label={t('services.listAriaLabel')}>
				<li>
					<button type="button" class="services__badge active" data-index="0">
						{t('services.badge0')}
					</button>
				</li>
				<li>
					<button type="button" class="services__badge" data-index="1">
						{t('services.badge1')}
					</button>
				</li>
				<li>
					<button type="button" class="services__badge" data-index="2">
						{t('services.badge2')}
					</button>
				</li>
			</ul>
		</div>

		<!-- Right column: image showcase -->
		<div class="services__col-right">
			<div class="services__media">
				<div class="services__media-frame">
					<div class="services__slide active" data-slide="0">
						<img
							src="/images/services/integracoes-ia.jpg"
							alt={t('services.slide0.alt')}
							class="services__img"
							loading="lazy"
						/>
						<div class="services__media-gradient" aria-hidden="true"></div>
						<p class="services__caption">
							{t('services.caption0')}
						</p>
					</div>
					<div class="services__slide" data-slide="1">
						<img
							src="/images/services/consultoria-ti.jpg"
							alt={t('services.slide1.alt')}
							class="services__img"
							loading="lazy"
						/>
						<div class="services__media-gradient" aria-hidden="true"></div>
						<p class="services__caption">
							{t('services.caption1')}
						</p>
					</div>
					<div class="services__slide" data-slide="2">
						<img
							src="/images/services/apps-mobile.jpg"
							alt={t('services.slide2.alt')}
							class="services__img"
							loading="lazy"
						/>
						<div class="services__media-gradient" aria-hidden="true"></div>
						<p class="services__caption">
							{t('services.caption2')}
						</p>
					</div>
				</div>
			</div>

		</div>
		</div>

		<div class="services__controls" aria-label="Controles do carrossel">


		<button
			type="button"
			class="services__nav-btn services__nav-btn--prev"
			aria-label={t('services.prev')}
			id="services-prev"
		>
			<span class="services__nav-icon services__nav-icon--left" aria-hidden="true"></span>
		</button>
		<button
			type="button"
			class="services__nav-btn services__nav-btn--next"
			aria-label={t('services.next')}
			id="services-next"
		>
			<span class="services__nav-icon services__nav-icon--right" aria-hidden="true"></span>
		</button>
		</div>
	</div>
</section>

<style>
	.services {
		padding-top: 9.5rem;
		color: #fff;
	}

	.services__inner {
		display: flex;
		flex-direction: row;
		align-items: stretch;
		gap: 2.5rem;
	}

	.services__col-left {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		flex: 0 1 449px;
		flex-shrink: 0;
		width: auto;
		align-self: flex-start;
	}

	.services__title-row {
		display: flex;
		align-items: flex-end;
		gap: 1rem;
	}

	.services__heading {
		margin: 0;
		font-family: "Inter", system-ui, sans-serif;
		font-size: 2.5rem;
		font-weight: 700;
		color: #fff;
	}

	.services__intro {
		display: flex;
		flex-direction: column;
	}

	.services__lead {
		margin: 0;
		font-family: "Roboto", system-ui, sans-serif;
		font-size: 1.25rem;
		font-weight: 400;
		color: #fff;
	}

	.services__list {
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.75rem;
		list-style: none;
	}

	.services__badge {
		display: inline-flex;
		align-items: center;
		cursor: pointer;
		border-radius: 9999px;
		border: 1px solid #d1d5db;
		background: transparent;
		padding: 0.5rem 18px;
		text-align: left;
		font-family: "Inter", system-ui, sans-serif;
		font-size: 1rem;
		font-weight: 600;
		color: #d1d5db;
	}

	.services__badge:hover {
		border-color: var(--accent-cyan);
		color: #fff;
	}

	.services__badge.active {
		border-color: #3b82f6;
		background-color: #3b82f6;
		color: #fff;
	}

	.services__col-right {
		display: flex;
		flex-direction: column;
		min-width: 0;
		min-height: 0;
		width: 100%;
		flex: 1 1 0;
	}

	.services__media {
		position: relative;
		width: 100%;
		flex: 1 1 auto;
		min-height: 0;
	}

	.services__media-frame {
		position: relative;
		overflow: hidden;
		border-radius: 1.5rem;
		flex: 1 1 auto;
		min-height: 320px;
	}

	.services__slide {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 0.4s ease;
		pointer-events: none;
	}

	.services__slide.active {
		opacity: 1;
		pointer-events: auto;
	}

	.services__img {
		display: block;
		height: 100%;
		width: 100%;
		object-fit: cover;
	}

	.services__media-gradient {
		pointer-events: none;
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(0, 0, 0, 0) 30%, rgba(0, 0, 0, 0.85) 100%);
	}

	.services__caption {
		position: absolute;
		bottom: 1.75rem;
		left: 1.75rem;
		right: 1.75rem;
		z-index: 2;
		margin: 0;
		font-family: var(--font-heading, "Inter", system-ui, sans-serif);
		font-size: 1.125rem;
		font-weight: 400;
		line-height: 1.3;
		color: #fff;
	}

	.services__controls {
		margin-top: 40px;
		display: flex;
		justify-content: flex-end;
		gap: 0.625rem;
	}

	.services__nav-btn {
		display: flex;
		height: 2.25rem;
		width: 2.25rem;
		cursor: pointer;
		align-items: center;
		justify-content: center;
		border-radius: 9999px;
		border: none;
		transition:
			transform 0.2s ease-in-out,
			background-color 0.2s ease-in-out;
	}

	/* Ícones de /public/icons/ — máscara para herdar `color` do botão */
	.services__nav-icon {
		display: block;
		width: 1.25rem;
		height: 1.171875rem; /* 16×15 */
		flex-shrink: 0;
		background-color: currentColor;
		-webkit-mask-size: contain;
		mask-size: contain;
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
		-webkit-mask-position: center;
		mask-position: center;
	}

	.services__nav-icon--left {
		-webkit-mask-image: url('/icons/arrow-left.svg');
		mask-image: url('/icons/arrow-left.svg');
	}

	.services__nav-icon--right {
		-webkit-mask-image: url('/icons/arrow-right.svg');
		mask-image: url('/icons/arrow-right.svg');
	}

	.services__nav-btn:hover {
		background-color: var(--accent-cyan) !important;
		transform: scale(1.08);
	}

	.services__nav-btn--prev {
		background-color: #d1d5db;
		color: #0e1213;
	}

	.services__nav-btn--next {
		background-color: #3b82f6;
		color: #0e1213;
	}

	.services__nav-btn--next:hover {
		background-color: #2563eb;
	}

	@media (max-width: 767px) {
		.services {
			position: relative;
			z-index: 1;
			padding-top: var(--section-padding-y-mobile);
			padding-bottom: 1.5rem;
		}

		.services__inner {
			flex-direction: column;
			align-items: stretch;
			gap: 2.5rem;
		}

		.services__col-left {
			flex: 1 1 auto;
			width: 100%;
			max-width: none;
			gap: 2.5rem;
		}

		.services__heading {
			font-size: 2rem; /* 32px — Figma mobile */
		}

		.services__lead {
			font-size: 1rem; /* 16px */
		}

		.services__badge {
			padding: 0.25rem 0.75rem;
			font-size: 0.75rem; /* 12px */
			font-weight: 600;
		}

		/* Evita coluna flex "esticando" e quebrando o contexto da legenda absoluta */
		.services__col-right {
			flex: 0 0 auto;
		}

		.services__media {
			flex: 0 0 auto;
			min-height: auto;
		}

		.services__media-frame {
			border-radius: 1.5rem; /* 24px */
			min-height: 12.9375rem; /* 207px — Figma mobile */
		}

		/* Figma 171:372 — legenda dentro do frame (mesmo CB do gradiente) */
		.services__caption {
			bottom: 1.5625rem; /* 25px */
			left: 1.9375rem; /* 31px */
			right: 1.25rem;
			top: auto;
			font-size: 0.75rem; /* 12px */
			line-height: 1.3;
			color: #fff;
		}

		.services__controls {
			margin-top: 1.25rem;
		}

		.services__nav-btn {
			width: 2rem;
			height: 2rem;
		}

		.services__nav-icon {
			width: 1rem;
			height: 0.9375rem;
		}
	}
</style>

<script>
	const badges = document.querySelectorAll<HTMLButtonElement>('.services__badge');
	const slides = document.querySelectorAll<HTMLElement>('.services__slide');
	let current = 0;

	function goTo(index: number) {
		badges[current].classList.remove('active');
		slides[current].classList.remove('active');
		current = ((index % slides.length) + slides.length) % slides.length;
		badges[current].classList.add('active');
		slides[current].classList.add('active');
	}

	badges.forEach((btn, i) => btn.addEventListener('click', () => goTo(i)));
	document.getElementById('services-prev')?.addEventListener('click', () => goTo(current - 1));
	document.getElementById('services-next')?.addEventListener('click', () => goTo(current + 1));
</script>
