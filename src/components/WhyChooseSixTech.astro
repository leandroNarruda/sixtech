---
import HeadingAccentBar from "./HeadingAccentBar.astro";
import type { FeatureCard } from "../data/whyChooseSixTech";
import { getWhyChooseFeatures } from "../data/whyChooseSixTech";
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

interface Props {
	features?: FeatureCard[];
	sectionId?: string;
}

const lang = (Astro.currentLocale ?? 'pt') as Lang;
const t = useTranslations(lang);

const { features = getWhyChooseFeatures(lang), sectionId = "quem-somos" } = Astro.props;
---

<section id={sectionId} class="features">
	<div class="container">
		<div class="features__panel">
			<div
				class="features__texture"
				aria-hidden="true"
				style="background: repeating-linear-gradient(-42deg, transparent, transparent 10px, rgba(255,255,255,0.04) 10px, rgba(255,255,255,0.04) 11px); mask-image: linear-gradient(to top, black 0%, transparent 85%); -webkit-mask-image: linear-gradient(to top, black 0%, transparent 85%);"
			/>

			<h2 class="features__title heading-with-accent">
				{t('why.heading')}<HeadingAccentBar />
			</h2>

			<div class="features__grid">
				{
					features.map((item) => (
						<article class="features__card">
							<div class="features__icon-wrap" aria-hidden="true">
								<img
									src={item.iconSrc}
									alt=""
									width="40"
									height="40"
									class="features__icon"
									loading="lazy"
									decoding="async"
								/>
							</div>
							<h3 class="features__card-title">
								{item.title}
							</h3>

							<div class="features__card-content">
								{"desc" in item ? (
									<p class="features__text font-roboto">
										{item.desc}
									</p>
								) : (
									<div class="features__stack">
										<p class="features__text font-roboto">{item.intro}</p>
										<ul class="features__list">
											{item.bullets.map((b) => (
												<li class="features__list-item">{b}</li>
											))}
										</ul>
										<p class="features__text font-roboto">{item.closing}</p>
									</div>
								)}
							</div>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	.features {
		position: relative;
		padding-top: 9.5rem;
	}

	.features__panel {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 5rem; /* 80px — Figma */
		overflow: hidden;
		border-radius: 2.5rem; /* 40px — Figma */
		background: var(--bg-surface);
		padding: 5rem; /* 80px */
	}

	.features__texture {
		pointer-events: none;
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 11rem;
		opacity: 0.35;
	}

	.features__title {
		position: relative;
		z-index: 1;
		margin: 0;
		max-width: 35.0625rem; /* 561px — Figma */
		text-align: left;
		font-size: var(--features-title-size);
		font-weight: 700;
		line-height: var(--features-title-line-height);
		letter-spacing: -0.025em;
		color: var(--text-main);
	}

	.features__grid {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.features__card {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		border-radius: 2rem; /* 32px — cards Figma */
		background: var(--color-figma-card);
		padding: 2.5rem;
		border: 1px solid transparent;
		box-shadow: 0 0 0 0 rgba(59, 130, 246, 0);
		transition:
			transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
			box-shadow 0.35s ease,
			border-color 0.35s ease;
		will-change: transform, box-shadow;
	}

	.features__card:hover {
		transform: translateY(-0.375rem);
		border-color: rgba(59, 130, 246, 0.25);
		box-shadow: 0 0 30px 0 rgba(59, 130, 246, 0.5);
	}

	.features__icon-wrap {
		margin-bottom: 1rem;
		flex-shrink: 0;
		filter: drop-shadow(0 8px 20px -6px rgba(59, 130, 246, 0.45));
		transition: filter 0.35s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.features__card:hover .features__icon-wrap {
		filter: drop-shadow(0 0 12px rgba(59, 130, 246, 0.75));
		transform: scale(1.12);
	}

	.features__icon {
		display: block;
		width: 2.5rem;
		height: 2.5rem;
	}

	.features__card-title {
		margin: 0 0 0.75rem;
		font-family: "Inter", system-ui, sans-serif;
		font-size: var(--features-card-title-size);
		font-weight: 700;
		line-height: 1.375;
		color: var(--color-figma-gray);
	}

	.features__text {
		margin: 0;
		font-size: var(--features-body-size);
		font-weight: 400;
		line-height: var(--features-body-line-height);
		color: var(--color-figma-gray);
	}

	.features__stack {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		font-family: var(--font-roboto);
		font-size: var(--features-body-size);
		font-weight: 400;
		line-height: var(--features-body-line-height);
		color: var(--color-figma-gray);
	}

	.features__list {
		margin: 0;
		padding-left: 1.25rem;
		list-style-type: disc;
	}

	.features__list-item::marker {
		color: var(--color-figma-gray);
	}

	.features__list-item {
		padding-left: 0.125rem;
		margin-top: 0.375rem;
	}

	.features__card-content {
		margin-top: 4.5rem; /* 72px — Figma gap icon block → corpo */
	}

	@media (max-width: 767px) {
		.features {
			position: relative;
			z-index: 2;
			/* Espaço claro após "O que fazemos" — evita o painel encostar/sobrepor a seção anterior */
			padding-top: clamp(7rem, 24vw, 10rem);
		}

		.features__panel {
			gap: 2.5rem; /* 40px — Figma mobile: título → cards */
			padding: 1.5rem; /* 24px */
			border-radius: 2.5rem; /* 40px */
		}

		.features__title {
			max-width: none;
			font-size: 2rem; /* 32px */
		}

		.features__grid {
			grid-template-columns: 1fr;
			gap: 2rem; /* 32px */
		}

		.features__card {
			padding: 1.5rem; /* 24px */
		}

		.features__card:hover {
			transform: none;
			box-shadow: 0 0 20px 0 rgba(59, 130, 246, 0.4);
		}

		.features__card:hover .features__icon-wrap {
			transform: none;
		}

		.features__icon-wrap {
			margin-bottom: 0.75rem; /* 12px — ícone → título */
		}

		.features__card-title {
			margin: 0;
		}

		.features__card-content {
			margin-top: 2.1875rem; /* 35px — Figma mobile */
		}
	}
</style>
